{
  "manifest_version": 3,
  "name": "NetPhantom",
  "version": "1.0.0",
  "description": "Real-Time 3D Network Visualizer — See the Matrix of requests behind any site",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "webRequest",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/interceptor.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "devtools_page": "devtools/devtools.html",
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "NetPhantom — 3D Network Visualizer",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["devtools/panel/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
